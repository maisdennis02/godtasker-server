# --- App ---
APP_URL=http://localhost:3333
NODE_ENV=development
PORT=3333

# --- Auth ---
APP_SECRET=change-me-to-a-long-random-string

# --- Database (used by config/database.js + sequelize-cli) ---
DB_HOST=localhost
DB_USER=postgres
DB_PASS=docker
DB_NAME=godtasker
DB_PORT=5432

# --- AWS S3 (file uploads via multer-s3) ---
AWS_REGION=us-east-1
AWS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=godtaskerfiles

# --- Resend (password reset emails) ---
# Leave RESEND_API_KEY empty to disable outbound email (codes are logged instead).
# MAIL_FROM must be on a domain verified in the Resend dashboard.
RESEND_API_KEY=
MAIL_FROM="GodTasker <no-reply@godtasker.app>"

# --- Firebase Admin (FCM push notifications) ---
# From your service account JSON. Keep PRIVATE_KEY in quotes; literal "\n" will be converted at runtime.
FCM_PROJECT_ID=godtasker-development
FCM_PRIVATE_KEY_ID=
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@godtasker-development.iam.gserviceaccount.com
FCM_CLIENT_ID=
FCM_DATABASE_URL=https://godtasker-development.firebaseio.com
