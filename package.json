{
  "name": "godtasker-server",
  "version": "2.0.0",
  "description": "GodTasker backend — REST + WebSocket server connecting users and workers.",
  "main": "src/server.js",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:debug": "nodemon --inspect src/server.js",
    "build": "sucrase ./src -d ./dist --transforms imports",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "db:migrate": "sequelize db:migrate",
    "db:migrate:undo": "sequelize db:migrate:undo",
    "db:seed": "sequelize db:seed:all"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "multer-s3": "^3.0.1",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "resend": "^6.17.2",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.1",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "sequelize-cli": "^6.6.2",
    "sucrase": "^3.35.0"
  }
}
